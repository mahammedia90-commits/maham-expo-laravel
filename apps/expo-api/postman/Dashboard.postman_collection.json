{
	"info": {
		"_postman_id": "dash-0001-a2b3-c4d5-e6f7g8h9i0j1",
		"name": "Dashboard Statistics - Maham Expo",
		"description": "Dashboard Statistics API collection for admin use.\nCovers overview stats, spaces filters, revenue filters, combined filters, user stats from auth service, and health checks.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{admin_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{"key": "auth_url", "value": "http://localhost:8001/api"},
		{"key": "expo_url", "value": "http://localhost:8002/api"},
		{"key": "admin_token", "value": ""},
		{"key": "event_id", "value": ""}
	],
	"item": [
		{
			"name": "1. Auth (تسجيل الدخول)",
			"item": [
				{
					"name": "Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Login successful', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('admin_token', jsonData.data.token);",
									"    pm.environment.set('admin_token', jsonData.data.token);",
									"    console.log('admin_token saved successfully');",
									"}",
									"",
									"pm.test('Token is present', function () {",
									"    pm.expect(jsonData.data).to.have.property('token');",
									"    pm.expect(jsonData.data.token).to.be.a('string').and.not.empty;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"admin@maham-expo.com\",\n  \"password\": \"Admin@123456\"\n}"
						},
						"url": {
							"raw": "{{auth_url}}/v1/auth/login",
							"host": ["{{auth_url}}"],
							"path": ["v1", "auth", "login"]
						},
						"description": "Login as admin to obtain the admin_token. The test script automatically saves the token to both collection and environment variables."
					},
					"response": []
				}
			],
			"description": "Authenticate as admin and store the bearer token for subsequent requests."
		},
