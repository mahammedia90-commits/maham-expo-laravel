{
	"info": {
		"name": "Maham Expo - Merchant",
		"description": "Merchant role endpoints for Maham Expo API.\nLogin as merchant first, then use the token for authenticated requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{merchant_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"pm.request.addHeader({ key: 'Accept', value: 'application/json' });",
					"pm.request.addHeader({ key: 'Accept-Language', value: pm.environment.get('language') || 'ar' });"
				]
			}
		}
	],
	"item": [
		{
			"name": "🔐 Auth",
			"item": [
				{
					"name": "Login as Merchant",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if(pm.response.code===200){var d=pm.response.json();if(d.data&&d.data.token){pm.environment.set('merchant_token',d.data.token);pm.environment.set('auth_token',d.data.token);}}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"merchant@example.com\",\n    \"password\": \"password\",\n    \"service_token\": \"{{service_token}}\",\n    \"service_name\": \"maham-expo\"\n}"
						},
						"url": {
							"raw": "{{auth_url}}/v1/auth/login",
							"host": [
								"{{auth_url}}"
							],
							"path": [
								"v1",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
