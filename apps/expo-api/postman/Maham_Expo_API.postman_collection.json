								"value": "Bearer {{token}}"
							},
							{
								"key": "Accept-Language",
								"value": "ar"
							}
						],
						"url": {
							"raw": "{{auth_url}}/auth/me",
							"host": ["{{auth_url}}"],
							"path": ["auth", "me"]
						},
						"description": "الحصول على بيانات المستخدم المسجل دخوله"
