# ============================================
# Maham Auth API - Production Environment
# ============================================
# Copy this file to .env and fill in the values
# For Coolify: Add these as environment variables

# ==================== APP ====================
APP_NAME="Maham Auth API"
APP_ENV=production
APP_KEY=                              # Will be auto-generated on first run
APP_DEBUG=false
APP_URL=https://auth.yourdomain.com   # Your domain
APP_TIMEZONE=Asia/Riyadh
APP_PORT=8001

# ==================== DATABASE ====================
DB_CONNECTION=mysql
DB_HOST=mysql                         # Service name in docker-compose
DB_PORT=3306
DB_DATABASE=auth_service
DB_USERNAME=auth_user
DB_PASSWORD=                          # Strong password (min 16 chars)
DB_ROOT_PASSWORD=                     # Strong root password

# ==================== REDIS ====================
REDIS_HOST=redis                      # Service name in docker-compose
REDIS_PORT=6379
REDIS_PASSWORD=                       # Optional: Redis password

# ==================== CACHE & SESSION ====================
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ==================== JWT ====================
JWT_SECRET=                           # Will be auto-generated on first run
JWT_TTL=60                            # Token lifetime in minutes
JWT_REFRESH_TTL=20160                 # Refresh token lifetime (14 days)

# ==================== MAIL ====================
# Option 1: Hostinger SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Maham Auth"

# Option 2: Gmail SMTP (use App Password)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password

# Option 3: Mailgun/SendGrid/etc
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=

# ==================== SERVICE AUTH ====================
SERVICE_TOKEN=                        # Generate: openssl rand -hex 32
TRUSTED_SERVICE_IPS=                  # Comma-separated IPs (optional)

# ==================== LOGGING ====================
LOG_CHANNEL=stack
LOG_LEVEL=error                       # error, warning, info, debug

# ==================== SECURITY ====================
BCRYPT_ROUNDS=12
TRUSTED_PROXIES=*                     # Trust Coolify proxy
