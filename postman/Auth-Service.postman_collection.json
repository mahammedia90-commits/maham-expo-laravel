{
	"info": {
		"_postman_id": "auth-service-001",
		"name": "Maham Auth Service",
		"description": "Complete authentication & authorization service API collection.\n\nBase URL: http://localhost:8001/api\n\nDefault credentials:\n- Super Admin: admin@example.com / password\n- Service Token: maham-expo-secret-token-2024",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"pm.request.addHeader({",
					"    key: 'Accept',",
					"    value: 'application/json'",
					"});",
					"pm.request.addHeader({",
					"    key: 'Accept-Language',",
					"    value: pm.environment.get('language') || 'ar'",
					"});"
				]
			}
		}
	],
	"item": [
		{
			"name": "🏥 Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{auth_url}}/health",
							"host": ["{{auth_url}}"],
							"path": ["health"]
						}
					}
				}
			]
		},
		{
			"name": "🔐 Authentication",
			"description": "Authentication endpoints - Login, Register, Password management",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        pm.environment.set('auth_token', jsonData.data.token);",
									"        pm.environment.set('user_id', jsonData.data.user.id);",
									"        console.log('Token saved successfully');",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"admin@example.com\",\n    \"password\": \"password\",\n    \"service_token\": \"{{service_token}}\",\n    \"service_name\": \"maham-expo\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{auth_url}}/v1/auth/login",
