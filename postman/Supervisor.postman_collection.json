{
	"info": {
		"_postman_id": "sup-b2c3d4e5-f6a7-8901-bcde-f12345678901",
		"name": "Supervisor (مشرف)",
		"description": "Maham Expo API - Supervisor (مشرف) Collection\n\nA supervisor user can:\n- View dashboard statistics (same as admin)\n- View events, spaces, sections, services (read-only - NO create/update/delete)\n- Approve/reject visit requests (after investor approval)\n- Approve/reject rental requests (after investor approval)\n- Record payments\n- View and manage business profiles (approve/reject)\n\nNOTE: Supervisors CANNOT delete anything!",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{supervisor_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{"key": "auth_url", "value": "http://localhost:8001/api"},
		{"key": "expo_url", "value": "http://localhost:8002/api"},
		{"key": "supervisor_token", "value": ""},
		{"key": "event_id", "value": ""},
		{"key": "space_id", "value": ""},
		{"key": "section_id", "value": ""},
		{"key": "service_id", "value": ""},
		{"key": "visit_request_id", "value": ""},
		{"key": "rental_request_id", "value": ""},
		{"key": "profile_id", "value": ""}
	],
	"item": [
		{
			"name": "Auth (تسجيل الدخول)",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('supervisor_token', jsonData.data.token);",
									"    pm.environment.set('supervisor_token', jsonData.data.token);",
									"    console.log('supervisor_token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {"type": "noauth"},
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"supervisor@maham-expo.com\",\n  \"password\": \"Supervisor@123456\"\n}"
						},
						"url": {
							"raw": "{{auth_url}}/auth/login",
							"host": ["{{auth_url}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Me (معلوماتي)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{auth_url}}/auth/me",
							"host": ["{{auth_url}}"],
							"path": ["auth", "me"]
						}
					}
				}
			]
		},
		{
			"name": "Dashboard (لوحة التحكم)",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{expo_url}}/v1/supervisor/dashboard",
							"host": ["{{expo_url}}"],
							"path": ["v1", "supervisor", "dashboard"],
							"query": [
								{"key": "event_id", "value": "", "disabled": true},
								{"key": "spaces_period", "value": "month", "disabled": true},
								{"key": "revenue_period", "value": "month", "disabled": true}
							]
						}
					}
				}
			]
		},
