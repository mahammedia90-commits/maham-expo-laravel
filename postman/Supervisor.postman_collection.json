		{
			"name": "Visit Requests (طلبات الزيارة)",
			"item": [
				{
					"name": "List Visit Requests",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{expo_url}}/v1/supervisor/visit-requests",
							"host": ["{{expo_url}}"],
							"path": ["v1", "supervisor", "visit-requests"],
							"query": [
								{"key": "status", "value": "pending", "disabled": true},
								{"key": "investor_status", "value": "approved", "disabled": true, "description": "Filter ready for supervisor approval"},
								{"key": "event_id", "value": "", "disabled": true},
								{"key": "search", "value": "", "disabled": true}
							]
						}
					}
				},
				{
					"name": "Show Visit Request",
					"request": {
						"method": "GET",
						"header": [
