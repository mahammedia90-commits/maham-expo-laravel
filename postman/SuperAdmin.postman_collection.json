        {
          "name": "Get OTP Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_url}}/v1/admin/otp/stats",
              "host": [
                "{{auth_url}}"
              ],
              "path": [
                "v1",
                "admin",
                "otp",
                "stats"
              ]
            },
            "description": "Get OTP usage statistics: sent count, logins, registrations — grouped by today, this week, this month. Also includes current balance and provider info.\n\nRequires: `admin` or `super-admin` role."
          }
        },
        {
          "name": "Test Send OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+966500000000\",\n    \"channel\": \"sms\",\n    \"provider\": \"authentica\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{auth_url}}/v1/admin/otp/test-send",
              "host": [
                "{{auth_url}}"
              ],
              "path": [
                "v1",
                "admin",
                "otp",
                "test-send"
              ]
            },
            "description": "Test sending an OTP to a phone number. In test mode, no actual SMS is sent.\n\n**Body:**\n- `phone` (required) — phone number e.g. +966500000000\n- `channel` (optional) — `sms` or `whatsapp` (default: sms)\n- `provider` (optional) — `authentica` or `twilio`\n\nRequires: `admin` or `super-admin` role."
          }
        }
      ]
    },
