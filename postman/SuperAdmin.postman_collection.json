{
	"info": {
		"_postman_id": "sa-a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Super Admin (مدير عام)",
		"description": "Maham Expo API - Super Admin Collection\n\nA super admin user can:\n- Full system access (everything admin can do)\n- Manage categories (CRUD)\n- Manage cities (CRUD)\n- Manage users/profiles (approve, reject, suspend)\n- System settings management\n- Extended dashboard with analytics (most viewed events/spaces by platform)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{super_admin_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{"key": "auth_url", "value": "http://localhost:8001/api"},
		{"key": "expo_url", "value": "http://localhost:8002/api"},
		{"key": "super_admin_token", "value": ""},
		{"key": "category_id", "value": ""},
		{"key": "city_id", "value": ""},
		{"key": "profile_id", "value": ""}
	],
	"item": [
		{
			"name": "Auth (تسجيل الدخول)",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('super_admin_token', jsonData.data.token);",
									"    pm.environment.set('super_admin_token', jsonData.data.token);",
									"    console.log('super_admin_token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {"type": "noauth"},
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"super-admin@maham-expo.com\",\n  \"password\": \"SuperAdmin@123456\"\n}"
						},
						"url": {
							"raw": "{{auth_url}}/auth/login",
							"host": ["{{auth_url}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Me (معلوماتي)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{auth_url}}/auth/me",
							"host": ["{{auth_url}}"],
							"path": ["auth", "me"]
						}
					}
				}
			]
		},
		{
			"name": "Dashboard (لوحة التحكم)",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{expo_url}}/v1/super-admin/dashboard",
							"host": ["{{expo_url}}"],
							"path": ["v1", "super-admin", "dashboard"]
						}
					}
				},
				{
					"name": "Dashboard with Filters",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ar"}
						],
						"url": {
							"raw": "{{expo_url}}/v1/super-admin/dashboard?analytics_period=month&spaces_period=month&revenue_period=year",
							"host": ["{{expo_url}}"],
							"path": ["v1", "super-admin", "dashboard"],
							"query": [
								{"key": "analytics_period", "value": "month", "description": "today|week|month|year|all"},
								{"key": "spaces_period", "value": "month"},
								{"key": "revenue_period", "value": "year"},
								{"key": "event_id", "value": "", "disabled": true}
							]
						}
					}
				}
			]
		},
