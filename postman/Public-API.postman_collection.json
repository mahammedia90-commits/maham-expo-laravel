			"name": "🏥 Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{expo_url}}/health",
							"host": [
								"{{expo_url}}"
							],
							"path": [
								"health"
							]
						}
					}
				}
			]
		},
