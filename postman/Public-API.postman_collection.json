		{
			"name": "Tracking",
			"description": "User activity tracking — works with or without authentication. X-Platform header recommended.",
			"item": [
				{
					"name": "Track View",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							},
							{
								"key": "X-Platform",
								"value": "web"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resource_type\": \"event\",\n  \"resource_id\": \"{{event_id}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{expo_url}}/v1/track/view",
							"host": [
								"{{expo_url}}"
							],
							"path": [
								"v1",
								"track",
								"view"
							]
						},
						"description": "Track a page/resource view. Supports: event, space, section, sponsor, page, banner, faq, service."
					}
				},
				{
					"name": "Track Action",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							},
							{
								"key": "X-Platform",
								"value": "web"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"search\",\n  \"metadata\": {\n    \"search_query\": \"\\u0645\\u0639\\u0631\\u0636 \\u0627\\u0644\\u0631\\u064a\\u0627\\u0636\",\n    \"source_page\": \"home\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{expo_url}}/v1/track/action",
							"host": [
								"{{expo_url}}"
							],
							"path": [
								"v1",
								"track",
								"action"
							]
						},
						"description": "Track a user action (search, click, share, filter, download, favorite, etc.)."
					}
				},
				{
					"name": "Track Action — Click",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							},
							{
								"key": "X-Platform",
								"value": "mobile"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"click\",\n  \"resource_type\": \"banner\",\n  \"resource_id\": \"{{banner_id}}\",\n  \"metadata\": {\n    \"source_page\": \"home\",\n    \"target_url\": \"/events/123\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{expo_url}}/v1/track/action",
							"host": [
								"{{expo_url}}"
							],
							"path": [
								"v1",
								"track",
								"action"
							]
						},
						"description": "Track a click action on a specific resource."
					}
				}
			]
		}
