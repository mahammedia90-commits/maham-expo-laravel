{
	"info": {
		"_postman_id": "public-api-001",
		"name": "Maham Expo - Public API",
		"description": "Public endpoints that do not require authentication.\nBase URL: http://localhost:8002/api",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"pm.request.addHeader({ key: 'Accept', value: 'application/json' });",
					"pm.request.addHeader({ key: 'Accept-Language', value: pm.environment.get('language') || 'ar' });"
				]
			}
		}
	],
	"item": [
